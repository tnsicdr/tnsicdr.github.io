{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["dom", "ESNext"],
        "jsx": "preserve",
        "module": "ESNext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noEmit": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*", "types"],
    "exclude": ["node_modules"]
}
